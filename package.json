{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist out",
    "lint": "tsc --noEmit",
    "start": "electron .",
    "dist": "electron-packager . \"동학년게시판\" --platform=win32 --arch=x64 --out=out --overwrite --ignore=out --ignore=scratch --ignore=\\.git",
    "dist:exe": "vite build && electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/myungsin89-cell/Bulletin-Board.git"
  },
  "build": {
    "appId": "com.donghaknyeon.board",
    "productName": "동학년게시판",
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "myungsin89-cell",
      "repo": "Bulletin-Board"
    },
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.js",
      "firebase-applet-config.json",
      "package.json"
    ],
    "win": {
      "icon": "src/assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "동학년게시판"
    }
  },
  "dependencies": {
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^43.1.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.4",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
